DJANGO_SECRET_KEY=change-me-to-a-random-secret-key
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_NAME=finance_tracker
DB_USER=postgres
DB_PASSWORD=change-me
DB_HOST=db
DB_PORT=5432

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CACHE_URL=redis://redis:6379/1

FRONTEND_URL=http://localhost:5173
# Optional comma-separated override for all allowed CORS origins.
# If empty, backend falls back to FRONTEND_URL + localhost defaults.
CORS_ALLOWED_ORIGINS=

# Vercel AI Gateway (optional: if missing, AI features use fallback)
AI_GATEWAY_KEY=your-ai-gateway-key-here
AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1/chat/completions
AI_GATEWAY_MODEL=xai/grok-4.1-fast-non-reasoning
AI_SUGGESTIONS_TIMEOUT=10

# AI Categorization
AI_CATEGORIZATION_ENABLED=true
AI_CATEGORIZATION_BATCH_SIZE=20
AI_CATEGORIZATION_TIMEOUT=15
AI_CATEGORIZATION_CACHE_TTL=2592000
